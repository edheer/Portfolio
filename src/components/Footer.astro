<script>
  // Script voor de live klok (Agency vibe)
  function updateClock() {
    const clockElement = document.getElementById('local-clock');
    if (clockElement) {
      const now = new Date();
      const options = { timeZone: 'Europe/Amsterdam', hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' };
      clockElement.innerText = now.toLocaleTimeString('nl-NL', options);
    }
  }
  setInterval(updateClock, 1000);
  updateClock();
</script>