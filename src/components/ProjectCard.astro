---
interface Props {
  title: string;
  category: string;
  image: string;
  link: string;
  year: string;
}

const { title, category, image, link, year } = Astro.props;
---

<a href={link} class="group relative block w-full h-full overflow-hidden rounded-[2rem] bg-neutral-900 border border-white/5 transition-all duration-500 hover:border-[#befc28]/40">
  
  <!-- Afbeelding: Aspect ratio vastzetten voor een strak grid -->
  <div class="relative aspect-[4/3] md:aspect-auto md:h-full overflow-hidden">
    <img 
      src={image} 
      alt={title} 
      class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-1000 opacity-40 group-hover:opacity-80"
    />
    
    <!-- Subtiele Gradient over de onderkant -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
  </div>

  <!-- Tekst Content: Nu IN het blok en veel kleiner -->
  <div class="absolute inset-0 p-6 md:p-8 flex flex-col justify-end">
    <div class="translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
        <div class="flex items-center gap-3 mb-2">
            <span class="text-[#befc28] font-mono text-[9px] font-bold tracking-[0.3em]">{year}</span>
            <span class="w-1 h-1 bg-white/20 rounded-full"></span>
            <span class="text-white/40 font-mono text-[9px] uppercase tracking-[0.2em]">{category}</span>
        </div>
        
        <!-- De titel is nu bescheiden (text-2xl) maar krachtig -->
        <h3 class="text-xl md:text-2xl font-black italic uppercase tracking-tight text-white group-hover:text-[#befc28] transition-colors">
            {title}
        </h3>
    </div>
  </div>

  <!-- Icon in de hoek -->
  <div class="absolute top-6 right-6 w-10 h-10 rounded-full border border-white/10 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500 bg-white/5 backdrop-blur-md">
    <span class="text-[#befc28] text-sm">↗</span>
  </div>
</a>