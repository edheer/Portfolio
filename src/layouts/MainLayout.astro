---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import '../styles/global.css';
const { title } = Astro.props;
---
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Emma de Heer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,900;1,900&display=swap" rel="stylesheet">
    <ClientRouter />
  </head>
  <body class="bg-[#050505] text-white antialiased overflow-x-hidden">
    <div class="grain"></div>
    <Header />
    
    <!-- Geen max-width hier, zodat de hero 100% breed kan zijn -->
    <main class="pt-24 w-full">
      <slot />
    </main>

    <footer class="py-20 text-center border-t border-white/5 mt-20">
      <p class="text-white/20 text-[10px] tracking-[0.5em] uppercase">© 2025 Emma de Heer — Twinpixel</p>
    </footer>
  </body>
</html>